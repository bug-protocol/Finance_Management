{
  "info": {
    "name": "Finance Dashboard API",
    "_postman_id": "6ab7d205-a5f0-4f41-8f43-5de64f1f80f6",
    "description": "Postman collection for the Finance Dashboard backend. Includes auth, user management, record CRUD, filtering, and dashboard analytics requests aligned with the current API behavior.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "adminEmail",
      "value": "admin@finance.local"
    },
    {
      "key": "adminPassword",
      "value": "Password123"
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "recordId",
      "value": ""
    },
    {
      "key": "createdBy",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication requests. Use Login first to store the JWT token in the collection variable.",
      "item": [
        {
          "name": "Register Viewer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo Viewer\",\n  \"email\": \"demo.viewer@example.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Public registration endpoint. New users are always created with the `viewer` role."
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (pm.response.code === 200 && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "  pm.collectionVariables.set('createdBy', json.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Logs in with the seeded admin account and stores the JWT in `{{token}}`."
          }
        }
      ]
    },
    {
      "name": "Users",
      "description": "Admin-only user management endpoints.",
      "item": [
        {
          "name": "Update Role",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"analyst\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/role",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}",
                "role"
              ]
            },
            "description": "Promotes or demotes a user. Requires an admin token."
          }
        },
        {
          "name": "Update Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"inactive\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}",
                "status"
              ]
            },
            "description": "Activates or deactivates a user."
          }
        }
      ]
    },
    {
      "name": "Records",
      "description": "Financial record CRUD plus filtering and pagination.",
      "item": [
        {
          "name": "Create Record",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if ((pm.response.code === 200 || pm.response.code === 201) && json.data && json.data._id) {",
                  "  pm.collectionVariables.set('recordId', json.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1850,\n  \"type\": \"income\",\n  \"category\": \"Salary\",\n  \"date\": \"2026-04-01\",\n  \"notes\": \"April salary payout\",\n  \"created_by\": \"{{createdBy}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/records",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "records"
              ]
            },
            "description": "Admin-only record creation. Saves the created record id into `{{recordId}}`."
          }
        },
        {
          "name": "List Records",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/records?page=1&limit=10&type=income&category=Salary&search=salary",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "records"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "type",
                  "value": "income"
                },
                {
                  "key": "category",
                  "value": "Salary"
                },
                {
                  "key": "search",
                  "value": "salary"
                }
              ]
            },
            "description": "Lists records with pagination, exact filters, and search."
          }
        },
        {
          "name": "Get Record By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/records/{{recordId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "records",
                "{{recordId}}"
              ]
            },
            "description": "Fetches a single record by id."
          }
        },
        {
          "name": "Update Record",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Updated from Postman demo\",\n  \"category\": \"Salary Bonus\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/records/{{recordId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "records",
                "{{recordId}}"
              ]
            },
            "description": "Admin-only partial update."
          }
        },
        {
          "name": "Delete Record",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/records/{{recordId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "records",
                "{{recordId}}"
              ]
            },
            "description": "Admin-only soft delete."
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "description": "Finance summary and aggregation endpoints.",
      "item": [
        {
          "name": "Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/dashboard/summary?created_by={{createdBy}}&startDate=2026-01-01&endDate=2026-12-31",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "dashboard",
                "summary"
              ],
              "query": [
                {
                  "key": "created_by",
                  "value": "{{createdBy}}"
                },
                {
                  "key": "startDate",
                  "value": "2026-01-01"
                },
                {
                  "key": "endDate",
                  "value": "2026-12-31"
                }
              ]
            },
            "description": "Returns total income, total expenses, net balance, category totals, monthly trends, and recent transactions."
          }
        }
      ]
    }
  ]
}
